{
  "autoCompactEnabled": true,
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(docker compose:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker exec:*)",
      "Bash(uv:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(pip install:*)",
      "Bash(npm install)",
      "Bash(npm run:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(curl -fsS:*)",
      "Bash(curl --silent:*)",
      "Bash(mkdir -p:*)",
      "Bash(touch:*)",
      "Bash(chmod +x:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(alembic:*)",
      "Bash(echo:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Edit(CLAUDE.md)",
      "Write(CLAUDE.md)",
      "Edit(specs/**)",
      "Write(specs/**)",
      "Edit(IMPLEMENTATION_PLAN.md)",
      "Write(IMPLEMENTATION_PLAN.md)",
      "Edit(AGENTS.md)",
      "Write(AGENTS.md)",
      "Bash(bash ~/.claude/plugins/cache/claude-plugins-official/ralph-loop/*/scripts/setup-ralph-loop.sh:*)"
    ],
    "ask": [
      "Bash(sudo:*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo delete:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard origin:*)"
    ]
  }
}
