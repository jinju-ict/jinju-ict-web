# 진주 정보통신개발 사이트 — 환경변수 (예시)
#
# 실제 secret 은 `.env.local` 에 두고 git 에 커밋하지 않는다.
# `.env.*` 는 .gitignore 가 차단함.

# ---------- 사이트 ----------

# Production canonical URL (예: https://jinju-ict.com).
# 미설정 시 VERCEL_URL (Vercel preview 등) → http://localhost:3000 fallback.
# metadata / robots / sitemap / OG 가 공유.
NEXT_PUBLIC_SITE_URL=https://jinju-ict.com


# ---------- 협업 문의 폼 ----------

# Resend API key — https://resend.com/api-keys 에서 발급.
# 무료 tier: 3000건/월, Vercel 1-clic 통합.
RESEND_API_KEY=re_xxx_replace_me

# 수신 이메일 (대표님) — Resend To: 에 사용.
CONTACT_INBOX_TO=teo.baek@outlook.com

# 발신 이메일 — 도메인 검증 전에는 onboarding@resend.dev 사용 가능 (테스트).
# 검증된 자체 도메인 보유 시 noreply@<domain> 으로 교체.
CONTACT_INBOX_FROM=onboarding@resend.dev
